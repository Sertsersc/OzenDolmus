<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/arka_plan"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Başlık -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚐 ÖZEN DOLMUŞ"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/beyaz"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.1"/>

        <!-- Şu anki saat -->
        <TextView
            android:id="@+id/tvSuankiSaat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textSize="16sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginTop="4dp"/>

        <!-- Konum / Durak bilgisi -->
        <TextView
            android:id="@+id/tvDurakBilgi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Konum alınıyor..."
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"
            android:background="#22FFFFFF"
            android:paddingVertical="6dp"
            android:paddingHorizontal="12dp"
            android:fontFamily="monospace"
            android:maxLines="2"/>

        <!-- Hat seçici butonlar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnOzen1"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🚐 Gidiş"
                android:textSize="14sp"
                android:backgroundTint="@color/ozen1_renk"
                android:textColor="@color/beyaz"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <Button
                android:id="@+id/btnOzen2"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔄 Dönüş"
                android:textSize="14sp"
                android:backgroundTint="@color/ozen2_renk"
                android:textColor="@color/beyaz"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <Button
                android:id="@+id/btnOzen3"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Özen 3"
                android:textSize="13sp"
                android:backgroundTint="@color/ozen3_renk"
                android:textColor="@color/beyaz"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <!-- Ana geri sayım kartı -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardGeriSayim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <!-- Hat adı -->
                <TextView
                    android:id="@+id/tvHatAdi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ÖZEN 1"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/hat_adi_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"/>

                <!-- Güzergah -->
                <TextView
                    android:id="@+id/tvGuzergah"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Özen Son Durak → Anadolu Lisesi"
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginTop="8dp"
                    android:gravity="center"/>

                <!-- Durum metni -->
                <TextView
                    android:id="@+id/tvKalanMetin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bir sonraki dolmuşa"
                    android:textSize="16sp"
                    android:textColor="#EEFFFFFF"
                    android:layout_marginTop="24dp"/>

                <!-- BÜYÜK GERİ SAYIM -->
                <TextView
                    android:id="@+id/tvGeriSayimBuyuk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="88sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:letterSpacing="-0.05"
                    android:layout_marginTop="8dp"
                    android:shadowColor="#44000000"
                    android:shadowDx="2"
                    android:shadowDy="4"
                    android:shadowRadius="8"/>

                <!-- Sefer saati -->
                <TextView
                    android:id="@+id/tvSeferSaati"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sefer saati: --:--"
                    android:textSize="18sp"
                    android:textColor="#DDFFFFFF"
                    android:layout_marginTop="8dp"/>

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="20dp"
                    android:progressTint="#FFFFFF"
                    android:progressBackgroundTint="#44FFFFFF"
                    android:max="100"
                    android:progress="50"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Son sefer"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gelecek"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"
                        android:gravity="end"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Yaklaşan seferler kartı -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 Yaklaşan Seferler"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#AAFFFFFF"/>

                <TextView
                    android:id="@+id/tvSonrakiSeferler"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--   --:--   --:--"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bilgi notu -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ℹ️ Tahmini tarife bazlı · Trafik durumuna göre değişebilir"
            android:textSize="12sp"
            android:textColor="#66FFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>
